# Smart Rename AI provider
# Copy this file to Herdr's private plugin config, then add your key.
OPENAI_API_KEY=

SMART_RENAME_PROVIDER=openai
SMART_RENAME_BASE_URL=https://api.openai.com/v1
SMART_RENAME_MODEL=gpt-5.6-luna
SMART_RENAME_REASONING_EFFORT=medium
SMART_RENAME_TIMEOUT_MS=45000

# Optional generic key for another OpenAI-compatible provider:
# SMART_RENAME_API_KEY=

# Optional custom prompt. Relative paths resolve from the plugin config directory:
# SMART_RENAME_PROMPT_PATH=naming-prompt.md
